
# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
set $term foot
set $termid foot
# Your preferred application launcher
set $menu wmenu-run
seat * xcursor_theme Bibata-Modern-Amber 32

include /etc/sway/config.d/*

# Clipboard https://github.com/savedra1/clipse?tab=readme-ov-file
exec_always clipse -listen
exec ~/.config/sway/scripts/battery-warn.sh
exec autotiling
default_orientation auto
exec ~/.config/sway/scripts/float-geometry-watcher.sh
exec_always ~/.config/sway/scripts/borders-follow-state.sh

set $popup popup

# Specific popups (self-contained: floating + resize + center)

for_window [app_id="$termid" title="^$popup-update"]         floating enable, resize set 1200 600, move position center
for_window [app_id="$termid" title="^$popup-settime$"]       floating enable, resize set 500 150,  move position center
for_window [app_id="$termid" title="^$popup-tuis"]           floating enable, resize set 1000 700, move position center

for_window [app_id="$termid" title="^$popup-f-aesthetics"]   floating enable, resize set 800 450,  move position center
for_window [app_id="$termid" title="^$popup-f-system"]       floating enable, resize set 850 600,  move position center
for_window [app_id="$termid" title="^$popup-f-devices"]      floating enable, resize set 750 650,  move position center
for_window [app_id="$termid" title="^$popup-f-wifi"]         floating enable, resize set 1450 450, move position center
for_window [app_id="$termid" title="^$popup-f-info"]         floating enable, resize set 1200 750, move position center
for_window [app_id="$termid" title="^$popup-f-main"]         floating enable, resize set 1800 400, move position center
for_window [app_id="$termid" title="^$popup-f-hardware"]     floating enable, resize set 1150 700, move position center

for_window [app_id="$termid" title="^$popup-wifi-check"]    floating enable, resize set 1200 1000, move position center
for_window [app_id="$termid" title="^$popup-wifi-select"]    floating enable, resize set 600 500, move position center
for_window [app_id="$termid" title="^$popup-wifi-device-select"] floating enable, resize set 500 500, move position center
for_window [app_id="$termid" title="^$popup-audio-select"]   floating enable, resize set 1200 100,  move position center

for_window [app_id="yazi-nvim"] floating enable, move position center, resize set 1000 700, opacity 0.85
for_window [app_id="PrismLauncher"] floating enable, move position center
for_window [app_id="glide"] opacity 0.85
for_window [app_id="chromium"] opacity 0.85
for_window [app_id="anki"] opacity 0.85
for_window [class="NotesHub"] opacity 0.85
for_window [app_id="signal"] opacity 0.85
for_window [app_id="$termid"] opacity 0.85
for_window [class="coda-qt"] opacity 0.85
for_window [title="^Collabora Office"] opacity 0.85
for_window [title="Collabora Office*"] opacity 0.85
for_window [class="discord"] opacity 0.85

bindsym F11 exec ~/.config/sway/scripts/toggle-opacity.sh

### Input configuration
   input type:touchpad {
       dwt enabled
       tap enabled
       accel_profile adaptive
       natural_scroll enabled
       middle_emulation enabled
   }

   input type:keyboard {
       xkb_layout "eu"
       xkb_options "compose:caps"
       repeat_delay 200
       repeat_rate 35
   }

   input type:pointer {
       accel_profile flat
       pointer_accel 0
   }

  input type:touch {
    tap enabled
    drag enabled
    drag_lock enabled
    map_to_output eDP-1
  }

# Disable broken touch screen, pen
input "1386:20983:Wacom_Pen_and_multitouch_sensor_Pen" {
    events disabled
}

input "1386:20983:Wacom_Pen_and_multitouch_sensor_Finger" {
  events disabled
}

